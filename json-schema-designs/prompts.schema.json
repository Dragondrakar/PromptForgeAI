{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PromptForge Prompts Vault",
  "type": "object",
  "properties": {
    "prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "original": { "type": "string" },
          "optimized": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "model": { "type": "string" },
          "rating": { "type": "number" },
          "created": { "type": "string", "format": "date-time" },
          "uses": { "type": "integer" }
        },
        "required": ["id", "title", "optimized", "created"]
      }
    }
  },
  "required": ["prompts"]
}